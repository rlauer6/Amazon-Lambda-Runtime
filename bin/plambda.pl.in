#!/usr/bin/env perl

use strict;
use warnings;

use English qw(-no_match_vars);
use Data::Dumper;

########################################################################
sub main {
########################################################################
  my ($lambda) = @_;

  ($lambda) = eval {

    die "no LAMBDA_MODULE defined in environment!\n"
      if !$ENV{LAMBDA_MODULE};

    my $lambda_module = $ENV{LAMBDA_MODULE};

    if ( $lambda_module =~ /::/xsm ) {
      $lambda_module =~ s/::/\//xsmg;
      $lambda_module = "$lambda_module.pm";
    }
    elsif ( $lambda_module !~ /[.]pm$/xsm ) {
      $lambda_module = "$lambda_module.pm";
    }

    require $lambda_module;

    return split /[.]pm\z/xsm, $ENV{LAMBDA_MODULE};
  };

  if ( !$lambda || $EVAL_ERROR ) {
    print {*STDERR} "ERROR: Could not initialize runtime\n$EVAL_ERROR\n";
    print {*STDERR} Dumper( [ env => \%ENV ] );

    return 1;
  }

  print {*STDERR} "invoking $lambda.handler\n";

  local $ENV{_HANDLER} = "$lambda.handler";

  return $lambda->new->run;
}

exit main(@ARGV);

1;

__END__

=pod

=head1 NAME

plambda.pl

=head1 SYNOPSIS

 plambda.pl $module

=head1 DESCRIPTION

Stub driver that invokes your AWS Lambda method.  Part of the Perl
Lambda Runtime system.

